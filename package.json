{
  "name": "diognosis",
  "version": "0.1.0-alpha.1",
  "description": "Source-linked medication safety and pharmacogenomics platform exploring drug interactions, metabolites, PK shifts, and genetic risk signals.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "stats": "node scripts/gen-stats.js",
    "check:evidence": "node scripts/check-evidence.js",
    "report:severity": "node scripts/severity-report.js",
    "audit:genotype-gaps": "node scripts/audit/genotype-gap-audit.js",
    "audit:data-views": "node scripts/audit/data-views-audit.js",
    "audit:evidence-review-ui": "node scripts/audit/evidence-review-ui-audit.js",
    "audit:evidence-calculation": "node scripts/audit/evidence-calculation-audit.js",
    "audit:evidence-review-queue": "node scripts/audit/evidence-review-queue.js",
    "audit:external-context-firewall": "node scripts/audit/external-context-firewall-audit.js",
    "audit:external-context-ui": "node scripts/audit/external-safety-context-ui-audit.js",
    "audit:open-targets": "node scripts/integrations/open-targets/import-open-targets.js --check",
    "audit:privacy-static": "node scripts/audit/privacy-static-audit.js",
    "audit:metabolite-coverage": "node scripts/audit/metabolite-coverage-audit.js",
    "audit:mechanistic-gaps": "node scripts/audit/mechanistic-curation-gaps.js",
    "enrich": "node scripts/enrich/pubmed-enrich.js",
    "enrich:pubmed": "node scripts/enrich/pubmed-enrich.js --providers pubmed",
    "enrich:batch": "node scripts/enrich/run-batch.js",
    "enrich:validate-batches": "node scripts/enrich/validate-batches.js",
    "enrich:self-test": "node scripts/enrich/pubmed-enrich.js --self-test",
    "integrate:open-targets": "node scripts/integrations/open-targets/import-open-targets.js",
    "build": "node build.js",
    "build:min": "node build.js --minify",
    "build:dev": "node build.js --out /tmp/diognosis_dev.html",
    "smoke": "node scripts/smoke-check.js",
    "launch:qa": "node scripts/launch-qa-audit.js",
    "launch:v1": "node scripts/launch-v1-check.js",
    "regression": "node scripts/regression-check.js",
    "validate": "node scripts/validate-db.js",
    "validate:strict": "node scripts/validate-db.js --strict",
    "release:check": "node scripts/release-check.js",
    "test": "node scripts/smoke-check.js && node scripts/regression-check.js && node scripts/validate-db.js && node scripts/check-evidence.js && node scripts/audit/external-context-firewall-audit.js && node scripts/audit/external-safety-context-ui-audit.js && node scripts/audit/evidence-review-queue.js --check && node scripts/integrations/open-targets/import-open-targets.js --check && node scripts/audit/privacy-static-audit.js"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1"
  }
}
